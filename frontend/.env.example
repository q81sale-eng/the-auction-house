# Supabase — required for auth (register / login / logout)
# Create a free project at https://supabase.com, then copy these from
# Project Settings → API
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Optional: self-hosted Laravel backend for auctions / marketplace data
# Leave unset to use the built-in demo data fallback
REACT_APP_API_URL=https://your-backend.example.com/api
